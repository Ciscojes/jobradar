# Opcion rapida para desarrollo:
DATABASE_URL=sqlite:///./jobradar.db

# Opcion SaaS local con Docker Compose:
# DATABASE_URL=postgresql://jobradar:jobradar@localhost:5432/jobradar
POSTGRES_DB=jobradar
POSTGRES_USER=jobradar
POSTGRES_PASSWORD=change-me

SECRET_KEY=dev-secret-change-me
#ACCESS_TOKEN_EXPIRE_MINUTES=60

# Adzuna: opcional. Si faltan, se usan datos de prueba.
# Consiguelas en https://developer.adzuna.com/
ADZUNA_APP_ID=tu_app_id
ADZUNA_APP_KEY=tu_app_key
ADZUNA_COUNTRY=es

# Telegram: opcional. Cada usuario configura su chat_id como canal.
TELEGRAM_BOT_TOKEN=tu_token

# Email SMTP: opcional. Si faltan, el envio se simula y se registra.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Scheduler: activo por defecto en desarrollo.
SCRAPER_SCHEDULER_ENABLED=true
SCRAPER_INTERVAL_MINUTES=10
SCRAPER_DEFAULT_QUERY=python

# Dashboard
JOBRADAR_API_URL=http://localhost:8000

# Docker Compose
API_PORT=8000
DASHBOARD_PORT=8501



# Local setup notes:
#   cp env.example .env
#   python -m venv .venv
#   .venv/bin/pip install -r requirements.txt
#   .venv/bin/dotenv -f .env run -- .venv/bin/alembic upgrade head
#   .venv/bin/uvicorn app.main:app --env-file .env --port 8000
