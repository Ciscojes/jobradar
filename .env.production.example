# Copia este archivo como .env en el entorno de producción y rellena los secretos.
# No lo subas con valores reales.

APP_ENV=production

# Base de datos
POSTGRES_DB=jobradar
POSTGRES_USER=jobradar
POSTGRES_PASSWORD=change-me-use-a-long-random-password
# Si usas una base gestionada externa, define DATABASE_URL en la plataforma.
# DATABASE_URL=postgresql://user:password@host:5432/jobradar

# Seguridad
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# HTTP / CORS
BACKEND_CORS_ORIGINS=https://app.example.com
DOCS_ENABLED=false
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO

# Adzuna
ADZUNA_APP_ID=replace-me
ADZUNA_APP_KEY=replace-me
ADZUNA_COUNTRY=es

# Telegram oficial de JobRadar
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_BOT_USERNAME=jobradar_oficial_bot

# Email SMTP opcional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Scheduler
SCRAPER_SCHEDULER_ENABLED=true
SCRAPER_INTERVAL_MINUTES=10
SCRAPER_DEFAULT_QUERY=python

# Puertos locales del contenedor/proxy
API_PORT=8000
DASHBOARD_PORT=8501
